# ═══════════════════════════════════════════════════════════════════════
# AGORA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env (está no .gitignore)
#
# Fluxo de configuração:
#   1. Expo app  → variáveis EXPO_PUBLIC_* (client-side, público)
#   2. Supabase Edge Functions → configurar em:
#      Dashboard → Settings → Edge Functions → Environment Variables
#   3. GitHub Actions → configurar em:
#      Repositório → Settings → Secrets and variables → Actions
# ═══════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────
# SUPABASE (obrigatório)
# Encontre em: https://app.supabase.com → Settings → API
# ─────────────────────────────────────────────────────────────────────

# URL do projeto Supabase (usado no app Expo e nas Edge Functions)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anônima — segura para expor no client (limitada por RLS)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Chave de service role — NUNCA exponha no client! Usar apenas em Edge Functions.
# Encontre em: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...


# ─────────────────────────────────────────────────────────────────────
# SEGURANÇA — Token interno entre serviços (obrigatório)
# ─────────────────────────────────────────────────────────────────────

# Segredo compartilhado entre Edge Functions e o app para chamadas internas.
# Gere com: openssl rand -base64 32   (ou qualquer UUID aleatório)
# Configurar em: Supabase Edge Functions env vars + GitHub Actions secrets
ALERT_SECRET=troque-por-string-aleatoria-segura-aqui


# ─────────────────────────────────────────────────────────────────────
# EMAIL — Resend (obrigatório para emails transacionais)
# https://resend.com → API Keys
# ─────────────────────────────────────────────────────────────────────

# Chave da API Resend — configurar em Supabase Edge Functions env vars
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetente dos emails. Deve ser um domínio verificado no Resend.
# Formato: "Nome <email@dominio.com>"
FROM_EMAIL=AGORA <nao-responda@agora.app>

# Email do administrador — recebe alertas de anomalias, denúncias e relatórios
# Configurar em: Supabase Edge Functions env vars
ADMIN_EMAIL=admin@agora.app

# Email do admin exposto ao client (para busca rápida sem chamada de API)
# Configurar também em: Supabase Edge Functions como ADMIN_EMAIL
EXPO_PUBLIC_ADMIN_EMAIL=admin@agora.app


# ─────────────────────────────────────────────────────────────────────
# APP — URL de produção
# ─────────────────────────────────────────────────────────────────────

# URL base do app (usado em links de email, botões de CTA)
# Exemplo: https://agora-vilhena.vercel.app
APP_URL=https://agora-vilhena.vercel.app

# URL pública exposta ao Expo app (deep links, OAuth callbacks)
EXPO_PUBLIC_APP_URL=https://agora-vilhena.vercel.app


# ─────────────────────────────────────────────────────────────────────
# ASAAS — Gateway de pagamento (obrigatório para planos pagos)
# https://sandbox.asaas.com → Integrações → API Keys
# ─────────────────────────────────────────────────────────────────────

# Token do Asaas. Use o sandbox para desenvolvimento.
# Sandbox:  https://sandbox.asaas.com
# Produção: https://www.asaas.com
# Configurar em: Supabase Edge Functions env vars
ASAAS_ACCESS_TOKEN=$aact_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ambiente Asaas: 'sandbox' | 'producao'
# Configurar em: Supabase Edge Functions env vars
ASAAS_ENV=sandbox


# ─────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (opcional — login social)
# https://console.cloud.google.com → APIs & Services → Credentials
# Configurar também em: Supabase → Authentication → Providers → Google
#
# O OAuth é mediado pelo Supabase — o app nunca chama a API Google diretamente.
# Apenas GOOGLE_CLIENT_ID e GOOGLE_CLIENT_SECRET são necessários aqui;
# configure-os também no Supabase Dashboard → Auth → Providers → Google.
# Authorized redirect URI no Google Cloud Console:
#   https://<project-ref>.supabase.co/auth/v1/callback
# Authorized JavaScript Origins:
#   https://agora-vilhena.vercel.app
# ─────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────
# APPLE SIGN IN (apenas iOS — obrigatório na App Store se usar outros OAuth)
# https://developer.apple.com → Certificates → Identifiers → Services IDs
# ─────────────────────────────────────────────────────────────────────

# Service ID do Apple Sign In (formato: com.agora.app.signin)
APPLE_CLIENT_ID=com.agora.app.signin

# JWT assinado com a Private Key gerada no Apple Developer Console
# Gerar com: https://supabase.com/docs/guides/auth/social-login/auth-apple
# O segredo expira a cada 6 meses — renovação necessária
APPLE_CLIENT_SECRET=eyJhbGci...

# ─────────────────────────────────────────────────────────────────────
# X / TWITTER OAUTH (opcional)
# https://developer.twitter.com → Developer Portal → Apps → Keys
# ─────────────────────────────────────────────────────────────────────

TWITTER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
TWITTER_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────
# DISCORD — Alertas de segurança e monitoramento (opcional)
# Discord → Server Settings → Integrations → Webhooks → New Webhook
# ─────────────────────────────────────────────────────────────────────

# Webhook URL do Discord para alertas de anomalia e auditoria crítica
# Configurar em: Supabase Edge Functions env vars
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy


# ─────────────────────────────────────────────────────────────────────
# GOOGLE MAPS (obrigatório para mapa no Android nativo)
# https://console.cloud.google.com → APIs & Services → Credentials
#
# APIs a habilitar no Google Cloud Console:
#   - Maps SDK for Android
# Restrição recomendada: SHA-1 do certificado do bundle com.agora.app
#
# Nota: iOS usa Apple Maps (sem API key). Web usa Leaflet via CDN (sem API key).
# Esta chave é injetada em app.config.js durante o build EAS.
# ─────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXX


# ─────────────────────────────────────────────────────────────────────
# EXPO / EAS — CI/CD e Build (obrigatório para deploy)
# https://expo.dev → Account Settings → Access Tokens
# ─────────────────────────────────────────────────────────────────────

# Token de acesso EAS — configurar em GitHub Actions secrets como EXPO_TOKEN
EXPO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do projeto EAS (gerado em: expo.dev → Projects)
# Também pode estar em app.json → extra.eas.projectId
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────
# SUPABASE CLI — Deploy de Edge Functions (CI/CD)
# https://app.supabase.com → Settings → General → Reference ID
# ─────────────────────────────────────────────────────────────────────

# ID de referência do projeto (encontrado na URL do dashboard)
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx

# Token de acesso pessoal Supabase (para deploy via CLI/CI)
# https://app.supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO DE DEPLOY DAS EDGE FUNCTIONS
# Configurar no Supabase Dashboard:
#   Settings → Edge Functions → Add new secret
#
# Variáveis necessárias em TODAS as Edge Functions:
#   - SUPABASE_URL              (injetado automaticamente)
#   - SUPABASE_SERVICE_ROLE_KEY (injetado automaticamente)
#   - SUPABASE_ANON_KEY         (injetado automaticamente)
#   - ALERT_SECRET              → adicionar manualmente
#   - RESEND_API_KEY            → adicionar manualmente
#   - FROM_EMAIL                → adicionar manualmente
#   - ADMIN_EMAIL               → adicionar manualmente
#   - APP_URL                   → adicionar manualmente
#   - ASAAS_ACCESS_TOKEN        → adicionar manualmente (asaas-webhook)
#   - DISCORD_WEBHOOK_URL       → adicionar manualmente (opcional)
# ─────────────────────────────────────────────────────────────────────
